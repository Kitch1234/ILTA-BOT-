import os


CHAMPION_PATH = "assets/champions"



def load_regions():

    champion_regions = {}



    if not os.path.exists(CHAMPION_PATH):

        print(
            "❌ Не найдена папка champions"
        )

        return {}




    for region in os.listdir(CHAMPION_PATH):


        region_path = os.path.join(

            CHAMPION_PATH,

            region

        )



        if not os.path.isdir(
            region_path
        ):

            continue





        for champion in os.listdir(region_path):


            champion_path = os.path.join(

                region_path,

                champion

            )



            if not os.path.isdir(
                champion_path
            ):

                continue



            champion_regions[champion] = region





    print(
        f"🌍 Регионов загружено для чемпионов: {len(champion_regions)}"
    )


    return champion_regions





# автоматическая загрузка

champion_regions = load_regions()
