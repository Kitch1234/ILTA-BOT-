from core import database



# Создать колоду

async def create_deck(
        owner_id,
        name
):

    query = """
    INSERT INTO decks
    (
        owner_id,
        name
    )
    VALUES
    (
        $1,
        $2
    )
    RETURNING id;
    """

    async with database.db.acquire() as conn:

        return await conn.fetchval(
            query,
            owner_id,
            name
        )



# Получить колоды игрока

async def get_decks(
        owner_id
):

    query = """
    SELECT *
    FROM decks
    WHERE owner_id = $1;
    """

    async with database.db.acquire() as conn:

        return await conn.fetch(
            query,
            owner_id
        )



# Добавить карту в колоду

async def add_card_to_deck(
        deck_id,
        card_id
):

    query = """
    INSERT INTO deck_cards
    (
        deck_id,
        card_id
    )
    VALUES
    (
        $1,
        $2
    );
    """

    async with database.db.acquire() as conn:

        await conn.execute(
            query,
            deck_id,
            card_id
        )
