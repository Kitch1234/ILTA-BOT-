import discord
from discord.ext import commands
import os
import asyncio

from dotenv import load_dotenv

from core.database import connect_db, close_db


load_dotenv()

TOKEN = os.getenv("TOKEN")


intents = discord.Intents.default()
intents.message_content = True


class QuantumBot(commands.Bot):

    def __init__(self):

        super().__init__(
            command_prefix="!",
            intents=intents
        )


    async def setup_hook(self):

        # подключение базы
        await connect_db()

        # загрузка модулей
        cogs = [
            "auction",
            "balance",
            "contract",
            "daily",
            "inventory",
            "profile",
            "quest",
            "shop",
            "work", "travel", "map"

        ]


        for cog in cogs:

            try:
                await self.load_extension(
                    f"cogs.{cog}"
                )

                print(
                    f"✅ Загружен модуль: {cog}.py"
                )

            except Exception as e:

                print(
                    f"❌ Ошибка {cog}.py:",
                    e
                )


        # синхронизация команд Discord
        try:

            synced = await self.tree.sync()

            print(
                f"✅ Синхронизировано команд: {len(synced)}"
            )

        except Exception as e:

            print(
                "❌ Ошибка синхронизации:",
                e
            )


    async def close(self):

        await close_db()

        await super().close()



bot = QuantumBot()



@bot.event
async def on_ready():

    print(
        f"🟢 Бот запущен: {bot.user}"
    )



async def main():

    if not TOKEN:

        print(
            "❌ TOKEN не найден в .env"
        )

        return


    await bot.start(TOKEN)



if __name__ == "__main__":

    try:

        asyncio.run(main())

    except KeyboardInterrupt:

        print(
            "Бот остановлен"
        )
