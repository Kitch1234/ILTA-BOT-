import os


CHAMPIONS_PATH = "assets/champions"



IMAGE_EXTENSIONS = (
    ".png",
    ".jpg",
    ".jpeg",
    ".webp"
)



def load_champions():


    champions = {}



    if not os.path.exists(CHAMPIONS_PATH):

        print(
            "❌ Папка champions не найдена"
        )

        return champions



    # регионы

    for region in os.listdir(CHAMPIONS_PATH):


        region_path = os.path.join(

            CHAMPIONS_PATH,

            region

        )


        if not os.path.isdir(region_path):

            continue



        # чемпионы

        for champion in os.listdir(region_path):


            champion_path = os.path.join(

                region_path,

                champion

            )


            if not os.path.isdir(champion_path):

                continue



            skins = []



            # образы

            for file in os.listdir(champion_path):


                if not file.lower().endswith(
                    IMAGE_EXTENSIONS
                ):

                    continue



                skin_name = os.path.splitext(
                    file
                )[0]



                skins.append({

                    "name": skin_name,

                    "file": os.path.join(

                        champion_path,

                        file

                    )

                })




            if skins:


                champions[champion] = {


                    "region": region,


                    "skins": skins


                }



                print(

                    f"✅ {region}: {champion} "
                    f"({len(skins)} образов)"

                )




    print(

        f"\nВсего чемпионов: {len(champions)}"

    )


    return champions
