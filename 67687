import os


CHAMPION_PATH = "assets/champions"



def load_champions():

    champions = {}



    if not os.path.exists(CHAMPION_PATH):

        print(
            "❌ Папка assets/champions не найдена"
        )

        return {}




    # регионы

    for region in os.listdir(CHAMPION_PATH):


        region_path = os.path.join(
            CHAMPION_PATH,
            region
        )


        if not os.path.isdir(
            region_path
        ):

            continue





        # чемпионы

        for champion in os.listdir(region_path):


            champion_path = os.path.join(
                region_path,
                champion
            )



            if not os.path.isdir(
                champion_path
            ):

                continue





            skins = []



            # образы

            for file in os.listdir(
                champion_path
            ):


                if file.lower().endswith(
                    (
                        ".png",
                        ".jpg",
                        ".jpeg",
                        ".webp"
                    )
                ):


                    skin_name = os.path.splitext(
                        file
                    )[0]



                    skins.append(

                        {
                            "name": skin_name,

                            "file": file,

                            "path": os.path.join(
                                champion_path,
                                file
                            )

                        }

                    )





            champions[champion] = {


                "name": champion,


                "region": region,


                "skins": skins


            }





    print(
        f"✅ Загружено чемпионов: {len(champions)}"
    )


    return champions
