import json
import os


FILE = "data/champions_ru.json"


if os.path.exists(FILE):

    with open(
        FILE,
        "r",
        encoding="utf-8"
    ) as f:

        TRANSLATIONS = json.load(f)

else:

    TRANSLATIONS = {}



def get_champion_ru(champion):

    data = TRANSLATIONS.get(
        champion,
        {}
    )

    return data.get(
        "name",
        champion
    )



def get_skin_ru(champion, skin):

    data = TRANSLATIONS.get(
        champion,
        {}
    )

    skins = data.get(
        "skins",
        {}
    )


    return skins.get(
        skin,
        skin.replace("_", " ")
    )



def get_region_ru(champion):

    data = TRANSLATIONS.get(
        champion,
        {}
    )

    region = data.get(
        "region",
        "Runeterra"
    )


    regions = {

        "Demacia": "Демасия",
        "Noxus": "Ноксус",
        "Freljord": "Фрельйорд",
        "Ionia": "Иония",
        "Shurima": "Шурима",
        "Void": "Пустота",
        "Shadow_Isles": "Сумрачные острова"

    }


    return regions.get(
        region,
        region
    )
