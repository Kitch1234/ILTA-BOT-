import discord
from discord.ext import commands
from discord import app_commands

from database import quest as quest_db


class Quest(commands.Cog):

    def __init__(self, bot):
        self.bot = bot


    @app_commands.command(
        name="quest",
        description="Показать доступные квесты"
    )
    async def quest(
        self,
        interaction: discord.Interaction
    ):

        quests = await quest_db.get_quests("start")

        if not quests:

            await interaction.response.send_message(
                "📜 В этом регионе нет квестов."
            )
            return


        text = "📜 Доступные квесты:\n\n"


        for q in quests:

            text += (
                f"№{q['id']} — {q['name']}\n"
                f"{q['description']}\n"
                f"🎯 Цель: {q['target']}\n"
                f"💰 Монеты: {q['reward_coins']}\n"
                f"⭐ Опыт: {q['reward_xp']}\n\n"
            )


        await interaction.response.send_message(
            text
        )



    @app_commands.command(
        name="quest_accept",
        description="Принять квест"
    )
    @app_commands.describe(
        quest_id="ID квеста"
    )
    async def quest_accept(
        self,
        interaction: discord.Interaction,
        quest_id: int
    ):

        await quest_db.accept_quest(
            interaction.user.id,
            quest_id
        )


        await interaction.response.send_message(
            f"✅ Квест №{quest_id} принят!"
        )



    @app_commands.command(
        name="quest_active",
        description="Показать активные квесты"
    )
    async def quest_active(
        self,
        interaction: discord.Interaction
    ):

        quests = await quest_db.get_player_quests(
            interaction.user.id
        )


        if not quests:

            await interaction.response.send_message(
                "📜 У вас нет активных квестов."
            )
            return


        text = "📜 Активные квесты:\n\n"


        for q in quests:

            status = "✅ Выполнен" if q["completed"] else "🔄 В процессе"


            text += (
                f"Квест №{q['quest_id']}\n"
                f"Прогресс: {q['progress']}/{q['target']}\n"
                f"{status}\n\n"
            )


        await interaction.response.send_message(
            text
        )



async def setup(bot):

    await bot.add_cog(
        Quest(bot)
    )
