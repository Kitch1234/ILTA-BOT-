# Обновить прогресс
# ==========================

async def update_progress(
        user_id,
        quest_id,
        progress
):

    query = """
    UPDATE player_quests
    SET progress = $3
    WHERE user_id = $1
    AND quest_id = $2;
    """


    async with database.db.acquire() as conn:

        await conn.execute(
            query,
            user_id,
            quest_id,
            progress
        )



