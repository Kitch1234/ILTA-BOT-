from core.database import db


async def get_quests(region):

    query = """
    SELECT *
    FROM quests
    WHERE TRIM(region) = TRIM($1);
    """

    return await db.fetch(
        query,
        region
    )


async def get_quest(quest_id):

    query = """
    SELECT *
    FROM quests
    WHERE id = $1;
    """

    return await db.fetchrow(
        query,
        quest_id
    )


async def accept_quest(discord_id, quest_id):

    query = """
    INSERT INTO player_quests (
        discord_id,
        quest_id,
        status
    )
    VALUES ($1, $2, 'active');
    """

    await db.execute(
        query,
        discord_id,
        quest_id
    )


async def get_player_quests(discord_id):

    query = """
    SELECT *
    FROM player_quests
    WHERE discord_id = $1;
    """

    return await db.fetch(
        query,
        discord_id
    )
