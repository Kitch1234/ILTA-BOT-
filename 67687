    @app_commands.command(
        name="deck_view",
        description="Посмотреть карты в колоде"
    )
    async def deck_view(
        self,
        interaction: discord.Interaction,
        deck_id: int
    ):

        cards = await deck_db.get_deck_cards(
            deck_id
        )


        if not cards:

            await interaction.response.send_message(
                "🃏 В колоде нет карт."
            )

            return


        text = f"🃏 Колода #{deck_id}\n\n"


        for card in cards:

            text += (
                f"🃏 {card['champion']}\n"
                f"⭐ {card['rarity']}\n"
                f"⚔️ {card['attack']} "
                f"🛡️ {card['defense']} "
                f"❤️ {card['health']}\n\n"
            )


        text += f"Всего карт: {len(cards)}/40"


        await interaction.response.send_message(
            text
        )
