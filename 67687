import discord
from discord.ext import commands
from discord import app_commands

from database import decks as deck_db


class Deck(commands.Cog):

    def __init__(self, bot):
        self.bot = bot


    @app_commands.command(
        name="deck_create",
        description="Создать колоду"
    )
    async def deck_create(
        self,
        interaction: discord.Interaction,
        name: str
    ):

        deck_id = await deck_db.create_deck(
            interaction.user.id,
            name
        )

        await interaction.response.send_message(
            f"🃏 Колода создана!\n"
            f"Название: {name}\n"
            f"ID: {deck_id}"
        )



    @app_commands.command(
        name="decks",
        description="Показать свои колоды"
    )
    async def decks(
        self,
        interaction: discord.Interaction
    ):

        await interaction.response.defer()


        try:

            result = await deck_db.get_decks(
                interaction.user.id
            )


            if not result:

                await interaction.followup.send(
                    "🃏 У вас нет колод."
                )

                return



            text = "🃏 Ваши колоды:\n\n"


            for deck in result:

                text += (
                    f"#{deck['id']} "
                    f"— {deck['name']}\n"
                )


            await interaction.followup.send(
                text
            )


        except Exception as e:

            print(
                "DECK ERROR:",
                e
            )

            await interaction.followup.send(
                f"❌ Ошибка:\n{e}"
            )
    @app_commands.command(
        name="deck_add",
        description="Добавить карту в колоду"
    )
    @app_commands.describe(
        deck_id="ID колоды",
        card_id="ID карты"
    )
    async def deck_add(
        self,
        interaction: discord.Interaction,
        deck_id: int,
        card_id: int
    ):

        try:

            await deck_db.add_card_to_deck(
                deck_id,
                card_id
            )


            await interaction.response.send_message(
                f"✅ Карта #{card_id} добавлена в колоду #{deck_id}"
            )


        except Exception as e:

            await interaction.response.send_message(
                f"❌ Ошибка:\n{e}"
            )
    @app_commands.command(
        name="deck_view",
        description="Посмотреть карты в колоде"
    )
    async def deck_view(
        self,
        interaction: discord.Interaction,
        deck_id: int
    ):

        cards = await deck_db.get_deck_cards(
            deck_id
        )


        if not cards:

            await interaction.response.send_message(
                "🃏 В колоде нет карт."
            )

            return


        text = f"🃏 Колода #{deck_id}\n\n"


        for card in cards:

            text += (
                f"🃏 {card['champion']}\n"
                f"⭐ {card['rarity']}\n"
                f"⚔️ {card['attack']} "
                f"🛡️ {card['defense']} "
                f"❤️ {card['health']}\n\n"
            )


        text += f"Всего карт: {len(cards)}/40"


        await interaction.response.send_message(
            text
        )

async def setup(bot):

    await bot.add_cog(
        Deck(bot)
    )
