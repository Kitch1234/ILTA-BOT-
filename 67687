import os

path = "source_assets/LoR"

count = 0

print("Поиск изображений LoR...")
print("------------------------")

for root, dirs, files in os.walk(path):
    for file in files:
        if file.lower().endswith((".png", ".jpg", ".webp")):
            print(os.path.join(root, file))
            count += 1

            if count >= 30:
                break

    if count >= 30:
        break

print("------------------------")
print("Найдено первых файлов:", count)
