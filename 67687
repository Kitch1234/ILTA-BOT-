import os

path = "source_assets/LoR/set1"

print("Проверяем:", path)
print("----------------")

for root, dirs, files in os.walk(path):
    level = root.replace(path, "").count(os.sep)

    if level > 3:
        continue

    indent = "    " * level
    print(indent + os.path.basename(root) + "/")

    for file in files[:5]:
        print(indent + "   " + file)
