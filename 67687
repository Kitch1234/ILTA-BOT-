import discord
from discord.ext import commands
from discord import app_commands

from database import quest as quest_db


class Quest(commands.Cog):

    def __init__(self, bot):
        self.bot = bot


    @app_commands.command(
        name="quest",
        description="Показать квесты"
    )
    async def quest(self, interaction: discord.Interaction):

        quests = await quest_db.get_quests("start")

        if not quests:
            await interaction.response.send_message(
                "Квестов нет."
            )
            return

        text = "Квесты:\n\n"

        for q in quests:
            text += (
                f"#{q['id']} {q['name']}\n"
                f"{q['description']}\n\n"
            )

        await interaction.response.send_message(text)


    @app_commands.command(
        name="quest_accept",
        description="Принять квест"
    )
    async def quest_accept(
        self,
        interaction: discord.Interaction,
        quest_id: int
    ):

        await quest_db.accept_quest(
            interaction.user.id,
            quest_id
        )

        await interaction.response.send_message(
            f"Квест {quest_id} принят."
        )


    @app_commands.command(
        name="quest_active",
        description="Активные квесты"
    )
    async def quest_active(
        self,
        interaction: discord.Interaction
    ):

        quests = await quest_db.get_player_quests(
            interaction.user.id
        )

        if not quests:
            await interaction.response.send_message(
                "Нет активных квестов."
            )
            return


        text = "Активные квесты:\n\n"

        for q in quests:

            text += (
                f"Квест #{q['quest_id']}\n"
                f"{q['progress']}/{q['target']}\n\n"
            )


        await interaction.response.send_message(text)



async def setup(bot):

    await bot.add_cog(
        Quest(bot)
    )
