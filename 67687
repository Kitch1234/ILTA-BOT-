import discord
from discord.ext import commands
from discord import app_commands

from database.cards import get_player_cards


class Collection(commands.Cog):
    def __init__(self, bot):
        self.bot = bot

    @app_commands.command(name="collection", description="Показать свою коллекцию карт")
    async def collection(self, interaction: discord.Interaction):
        cards = await get_player_cards(interaction.user.id)

        if not cards:
            await interaction.response.send_message("🃏 У тебя пока нет карт. Открой пак `/open_pack`")
            return

        embed = discord.Embed(
            title=f"🃏 Коллекция {interaction.user.name}",
            color=discord.Color.purple()
        )

        for card in cards:
            embed.add_field(
                name=f"{card['champion']} — {card['skin']}",
                value=f"⭐ {card['rarity']}\n⚔️ {card['attack']}  ❤️ {card['health']}  🛡️ {card['defense']}",
                inline=True
            )

        await interaction.response.send_message(embed=embed)


async def setup(bot):
    await bot.add_cog(Collection(bot))
