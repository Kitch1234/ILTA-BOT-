"""
События квестов ILTA BOT RPG
"""

from database import quest as quest_db


async def trigger_event(
        user_id,
        event,
        amount=1
):

    events = {

        "monster_kill": [
            1
        ],

        "boss_kill": [
            2
        ],

        "open_chest": [
            3
        ],

        "get_card": [
            4
        ],

        "move_region": [
            5
        ]

    }


    quest_ids = events.get(
        event,
        []
    )


    for quest_id in quest_ids:

        quests = await quest_db.get_player_quests(
            user_id
        )


        for quest in quests:

            if quest["quest_id"] != quest_id:
                continue


            if quest["completed"]:
                continue


            new_progress = (
                quest["progress"] + amount
            )


            if new_progress >= quest["target"]:

                await quest_db.complete_quest(
                    user_id,
                    quest_id
                )


            else:

                await quest_db.update_progress(
                    user_id,
                    quest_id,
                    new_progress
                )



async def monster_killed(user_id):

    await trigger_event(
        user_id,
        "monster_kill"
    )



async def boss_killed(user_id):

    await trigger_event(
        user_id,
        "boss_kill"
    )



async def chest_opened(user_id):

    await trigger_event(
        user_id,
        "open_chest"
    )



async def card_received(user_id):

    await trigger_event(
        user_id,
        "get_card"
    )



async def region_discovered(user_id):

    await trigger_event(
        user_id,
        "move_region"
    )
