import os


ASSETS_PATH = "assets/champions"



def get_champion_art(
    champion,
    skin_id
):
    """
    Получить локальный арт чемпиона
    """

    path = os.path.join(

        ASSETS_PATH,

        champion,

        f"{skin_id}.jpg"

    )


    if os.path.exists(path):

        return path



    return None
