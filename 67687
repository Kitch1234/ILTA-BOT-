import discord
from discord.ext import commands
from discord import app_commands

from database import cards as cards_db


class Cards(commands.Cog):

    def __init__(self, bot):
        self.bot = bot


    @app_commands.command(
        name="collection",
        description="Посмотреть свою коллекцию карт"
    )
    async def collection(
        self,
        interaction: discord.Interaction
    ):

        user_id = interaction.user.id


        cards = await cards_db.get_player_cards(
            user_id
        )


        if not cards:

            await interaction.response.send_message(
                "🃏 У вас пока нет карт."
            )

            return



        embed = discord.Embed(

            title=f"🃏 Коллекция {interaction.user.name}",

            color=0xFFD700
        )


        embed.description = (
            f"Всего карт: **{len(cards)}**\n"
        )



        for card in cards[:10]:

            embed.add_field(

                name=(
                    f"🎴 {card['champion']} "
                    f"({card['rarity']})"
                ),

                value=(

                    f"🆔 {card['card_code']}\n"

                    f"🎨 {card['skin']}\n"

                    f"🌍 {card['region']}\n"

                    f"⚔️ {card['attack']}  "
                    f"❤️ {card['health']}  "
                    f"🛡️ {card['defense']}"

                ),

                inline=False
            )



        if len(cards) > 10:

            embed.set_footer(

                text=f"Показано 10 из {len(cards)} карт"

            )


        await interaction.response.send_message(
            embed=embed
        )



async def setup(bot):

    await bot.add_cog(
        Cards(bot)
    )
