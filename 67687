import os

path = "source_assets"

print("Проверка папки:", path)
print("--------------------")

for root, dirs, files in os.walk(path):
    level = root.replace(path, "").count(os.sep)

    if level > 2:
        continue

    indent = "    " * level
    print(indent + os.path.basename(root) + "/")

    for file in files[:5]:
        print(indent + "    " + file)
