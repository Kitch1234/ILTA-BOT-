# database/cards.py

from core.database import db


# Получить карты игрока
async def get_player_cards(owner_id: int):

    query = """
    SELECT *
    FROM cards
    WHERE owner_id = $1
    ORDER BY created_at DESC;
    """

    async with db.acquire() as conn:
        return await conn.fetch(
            query,
            owner_id
        )



# Получить одну карту
async def get_card(card_id: int):

    query = """
    SELECT *
    FROM cards
    WHERE id = $1;
    """

    async with db.acquire() as conn:
        return await conn.fetchrow(
            query,
            card_id
        )



# Добавить карту игроку
async def add_card(
    owner_id: int,
    card_code: str,
    champion: str,
    skin: str,
    region: str,
    rarity: str,
    attack: int,
    defense: int,
    health: int
):

    query = """
    INSERT INTO cards
    (
        owner_id,
        card_code,
        champion,
        skin,
        region,
        rarity,
        attack,
        defense,
        health
    )

    VALUES
    (
        $1,$2,$3,$4,$5,$6,$7,$8,$9
    );
    """


    async with db.acquire() as conn:

        await conn.execute(
            query,
            owner_id,
            card_code,
            champion,
            skin,
            region,
            rarity,
            attack,
            defense,
            health
        )



# Получить количество карт игрока
async def get_cards_count(owner_id: int):

    query = """
    SELECT COUNT(*)
    FROM cards
    WHERE owner_id = $1;
    """

    async with db.acquire() as conn:

        result = await conn.fetchval(
            query,
            owner_id
        )

        return result
