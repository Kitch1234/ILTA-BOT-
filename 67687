from core.database import db


async def get_quests(region):

    query = """
    SELECT *
    FROM quests
    WHERE region = $1;
    """

    async with db.acquire() as conn:
        return await conn.fetch(
            query,
            region
        )


async def get_quest(quest_id):

    query = """
    SELECT *
    FROM quests
    WHERE id = $1;
    """

    async with db.acquire() as conn:
        return await conn.fetchrow(
            query,
            quest_id
        )


async def accept_quest(user_id, quest_id):

    quest = await get_quest(quest_id)

    if quest is None:
        return False


    query = """
    INSERT INTO player_quests (
        user_id,
        quest_id,
        progress,
        target,
        completed,
        claimed
    )
    VALUES ($1, $2, 0, $3, FALSE, FALSE);
    """


    async with db.acquire() as conn:
        await conn.execute(
            query,
            user_id,
            quest_id,
            quest["target"]
        )

    return True



async def get_player_quests(user_id):

    query = """
    SELECT *
    FROM player_quests
    WHERE user_id = $1;
    """

    async with db.acquire() as conn:
        return await conn.fetch(
            query,
            user_id
        )
