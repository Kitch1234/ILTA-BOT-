ASSET_PATH = "assets/champions"


class Pack(commands.Cog):

    def __init__(self, bot):

        self.bot = bot

        self.champions = load_champions()



    def find_skin_image(
        self,
        champion,
        skin
    ):

        for region in os.listdir(
            ASSET_PATH
        ):

            region_path = os.path.join(
                ASSET_PATH,
                region
            )


            if not os.path.isdir(
                region_path
            ):
                continue



            champion_path = os.path.join(
                region_path,
                champion
            )


            if not os.path.exists(
                champion_path
            ):
                continue



            files = os.listdir(
                champion_path
            )



            for file in files:

                filename = os.path.splitext(
                    file
                )[0]


                if filename.lower() == skin.lower():

                    return os.path.join(
                        champion_path,
                        file
                    )



        return None



