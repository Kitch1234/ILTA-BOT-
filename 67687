import os


ASSET_PATH = "assets/champions"



def load_available_cards():

    cards = []


    if not os.path.exists(ASSET_PATH):
        return cards



    for region in os.listdir(ASSET_PATH):

        region_path = os.path.join(
            ASSET_PATH,
            region
        )


        if not os.path.isdir(region_path):
            continue



        for champion in os.listdir(region_path):

            champion_path = os.path.join(
                region_path,
                champion
            )


            if not os.path.isdir(champion_path):
                continue




            for file in os.listdir(champion_path):


                if file.lower().endswith(
                    (
                        ".png",
                        ".jpg",
                        ".jpeg",
                        ".webp"
                    )
                ):


                    skin = os.path.splitext(file)[0]



                    cards.append({

                        "region": region,

                        "champion": champion,

                        "skin": skin,

                        "path": os.path.join(
                            champion_path,
                            file
                        )

                    })


    return cards
