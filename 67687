async def get_deck_cards(deck_id):

    query = """
    SELECT 
        cards.id,
        cards.champion,
        cards.skin,
        cards.rarity,
        cards.attack,
        cards.defense,
        cards.health

    FROM deck_cards

    JOIN cards
    ON cards.id = deck_cards.card_id

    WHERE deck_cards.deck_id = $1;
    """


    async with database.db.acquire() as conn:

        return await conn.fetch(
            query,
            deck_id
        )
