import random
from datetime import datetime, timedelta

import discord
from discord.ext import commands

from core.player import (
    create_player,
    get_player,
    add_coins,
    add_xp,
    set_last_work,
    level_up
)


class Work(commands.Cog):

    def __init__(self, bot):
        self.bot = bot

    @discord.app_commands.command(
        name="work",
        description="Заработать монеты"
    )
    async def work(self, interaction: discord.Interaction):

        await create_player(
            interaction.user.id,
            interaction.user.name
        )

        player = await get_player(
            interaction.user.id
        )

        if player["last_work"]:

            cooldown = timedelta(minutes=1)

            if datetime.utcnow() - player["last_work"] < cooldown:

                left = cooldown - (datetime.utcnow() - player["last_work"])

                await interaction.response.send_message(
                    f"⏳ Подождите ещё **{left.seconds} сек.**",
                    ephemeral=True
                )
                return

        coins = random.randint(10, 30)
        xp = random.randint(5, 15)

        await add_coins(
            interaction.user.id,
            coins
        )

        await add_xp(
            interaction.user.id,
            xp
        )

        await set_last_work(
            interaction.user.id
        )

        level = await level_up(
            interaction.user.id
        )

        embed = discord.Embed(
            title="💼 Работа завершена",
            color=discord.Color.green()
        )

        embed.add_field(
            name="💰 Монеты",
            value=f"+{coins}",
            inline=True
        )

        embed.add_field(
            name="⭐ Опыт",
            value=f"+{xp}",
            inline=True
        )

        if level:

            embed.add_field(
                name="🎉 Уровень",
                value="Вы повысили уровень!",
                inline=False
            )

        await interaction.response.send_message(
            embed=embed
        )


async def setup(bot):
    await bot.add_cog(Work(bot))
