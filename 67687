from core import database


# ==========================
# Получить квесты региона
# ==========================

async def get_quests(region):

    query = """
    SELECT *
    FROM quests
    WHERE region = $1;
    """

    async with database.db.acquire() as conn:

        return await conn.fetch(
            query,
            region
        )



# ==========================
# Получить один квест
# ==========================

async def get_quest(quest_id):

    query = """
    SELECT *
    FROM quests
    WHERE id = $1;
    """

    async with database.db.acquire() as conn:

        return await conn.fetchrow(
            query,
            quest_id
        )



# ==========================
# Принять квест
# ==========================

async def accept_quest(
        user_id,
        quest_id
):

    query = """
    INSERT INTO player_quests
    (
        user_id,
        quest_id,
        progress,
        target,
        completed,
        claimed
    )
    VALUES
    (
        $1,
        $2,
        0,
        (
            SELECT target
            FROM quests
            WHERE id = $2
        ),
        FALSE,
        FALSE
    );
    """


    async with database.db.acquire() as conn:

        await conn.execute(
            query,
            user_id,
            quest_id
        )


    return True



