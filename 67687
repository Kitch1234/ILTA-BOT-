import discord
from discord.ext import commands
from discord import app_commands
import random
import urllib.parse

from database.cards import add_card
from data.champion_loader import load_champions
from data.loot import get_random_rarity


class Pack(commands.Cog):
    def __init__(self, bot):
        self.bot = bot
        self.champions = load_champions()

    @app_commands.command(
        name="open_pack",
        description="Открыть пак из 10 карт"
    )
    async def open_pack(self, interaction: discord.Interaction):
        await interaction.response.defer()

        try:
            if not self.champions:
                await interaction.followup.send(
                    "❌ champions.json не найден!"
                )
                return

            await interaction.followup.send(
                f"🎁 **{interaction.user.name} открыл пак из 10 карт!**"
            )

            for i in range(10):

                # Выбор чемпиона
                champion_id = random.choice(
                    list(self.champions.keys())
                )

                champion = self.champions[champion_id]

                # Скин
                skin = random.choice(
                    champion.get("skins", ["Classic"])
                )

                # Редкость
                rarity = get_random_rarity()

                # Характеристики карты
                attack = random.randint(20, 70)
                health = random.randint(30, 100)
                defense = random.randint(5, 35)


                # Сохраняем карту
                await add_card(
                    interaction.user.id,
                    champion_id,
                    skin,
                    rarity,
                    attack,
                    defense,
                    health
                )


                # Создание Embed
                embed = discord.Embed(
                    title=f"🎴 {rarity} — {champion_id}",
                    description=f"✨ Скин: **{skin}**",
                    color=0xFFD700
                )


                embed.add_field(
                    name="⚔️ Атака",
                    value=str(attack),
                    inline=True
                )

                embed.add_field(
                    name="❤️ Здоровье",
                    value=str(health),
                    inline=True
                )

                embed.add_field(
                    name="🛡️ Защита",
                    value=str(defense),
                    inline=True
                )


                # Исправленный URL картинки
                safe_id = urllib.parse.quote(champion_id)

                image_url = (
                    "https://ddragon.leagueoflegends.com/"
                    "cdn/img/champion/splash/"
                    f"{safe_id}_0.jpg"
                )


                # Проверка URL
                if image_url.startswith("https://"):
                    embed.set_image(url=image_url)


                embed.set_footer(
                    text=f"Карта {i + 1}/10"
                )


                await interaction.followup.send(
                    embed=embed
                )


        except Exception as e:
            await interaction.followup.send(
                f"❌ Ошибка: {e}"
            )


async def setup(bot):
    await bot.add_cog(Pack(bot))
