import discord
from discord.ext import commands
from discord import app_commands

from database import cards as cards_db


class Cards(commands.Cog):

    def __init__(self, bot):
        self.bot = bot


    @app_commands.command(
        
        description="Посмотреть свою коллекцию карт"
    )
    async def collection(
        self,
        interaction: discord.Interaction
    ):

        user_id = interaction.user.id


        cards = await cards_db.get_player_cards(
            user_id
        )


        if not cards:

            await interaction.response.send_message(
                "🃏 У вас пока нет карт."
            )

            return


        text = (
            f"🃏 Коллекция {interaction.user.name}\n\n"
        )


        for card in cards:

            text += (
                f"🃏 {card['champion']}\n"
                f"🎨 Скин: {card['skin']}\n"
                f"⭐ Редкость: {card['rarity']}\n"
                f"⚔️ Атака: {card['attack']}\n"
                f"🛡️ Защита: {card['defense']}\n"
                f"❤️ Здоровье: {card['health']}\n\n"
            )


        await interaction.response.send_message(
            text
        )



async def setup(bot):

    await bot.add_cog(
        Cards(bot)
    )
